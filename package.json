{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "dax",
  "description": "DAX - Deterministic AI eXecution. Governed AI orchestration for real software delivery.",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "dev": "bun run --cwd packages/dax src/index.ts",
    "typecheck": "bun turbo typecheck",
    "typecheck:dax": "bun run --cwd packages/dax typecheck",
    "test": "bun --cwd packages/dax test",
    "build": "bun --cwd packages/dax build",
    "release:check": "bun run script/release-check.ts",
    "release:verify": "bun run release:check && bun run typecheck:dax && bun run test",
    "release": "bun run release:verify && bun run build",
    "release:publish": "DAX_RELEASE=1 bun run release",
    "release:publish:live": "DAX_RELEASE=1 DAX_RELEASE_DRAFT=0 DAX_RELEASE_PUBLISH=1 bun run release"
  },
  "workspaces": {
    "packages": [
      "packages/dax",
      "packages/plugin",
      "packages/util",
      "packages/script",
      "packages/sdk/js"
    ]
  },
  "catalog": {
    "@types/bun": "1.3.8",
    "@octokit/rest": "22.0.0",
    "@hono/zod-validator": "0.4.2",
    "ulid": "3.0.1",
    "@kobalte/core": "0.13.11",
    "@types/luxon": "3.7.1",
    "@types/node": "22.13.9",
    "@types/semver": "7.7.1",
    "@tsconfig/node22": "22.0.2",
    "@tsconfig/bun": "1.0.9",
    "@cloudflare/workers-types": "4.20251008.0",
    "@pierre/diffs": "1.0.2",
    "@solid-primitives/storage": "4.3.3",
    "diff": "8.0.2",
    "dompurify": "3.3.1",
    "ai": "5.0.124",
    "hono": "4.10.7",
    "hono-openapi": "1.1.2",
    "fuzzysort": "3.1.0",
    "luxon": "3.6.1",
    "marked": "17.0.1",
    "marked-shiki": "1.2.1",
    "typescript": "5.8.2",
    "@typescript/native-preview": "7.0.0-dev.20251207.1",
    "zod": "4.1.8",
    "remeda": "2.26.0",
    "shiki": "3.20.0",
    "solid-list": "0.3.0",
    "tailwindcss": "4.1.11",
    "virtua": "0.42.3",
    "vite": "7.1.4",
    "@solidjs/meta": "0.29.4",
    "@solidjs/router": "0.15.4",
    "solid-js": "1.9.10",
    "vite-plugin-solid": "2.11.10"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "turbo": "2.5.6",
    "prettier": "3.6.2"
  },
  "dependencies": {
    "typescript": "catalog:",
    "blessed": "^0.1.81"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dax-ai/dax"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  }
}
