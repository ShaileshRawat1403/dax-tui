# DAX local environment template (placeholders only)
# Copy to .env locally and fill real values.

# -----------------------------
# Gemini API mode (google/*)
# -----------------------------
GEMINI_API_KEY=__your_gemini_api_key__
# Alternative variable supported by some SDK paths:
# GOOGLE_API_KEY=__your_gemini_api_key__

# Optional OAuth client overrides for Gemini OAuth (email mode)
# DAX_GEMINI_OAUTH_CLIENT_ID=106908510407-11jel09tjvo8rp57o035feggqo6vla46.apps.googleusercontent.com
# DAX_GEMINI_OAUTH_CLIENT_SECRET=
# OAuth scope mode:
# compat = openid + email + profile + cloud-platform (default)
# full = also requests generative-language.retriever
# DAX_GEMINI_OAUTH_SCOPE_MODE=compat

# -----------------------------
# Vertex mode (google-vertex/*)
# -----------------------------
GOOGLE_CLOUD_PROJECT=the-soothsayer
# GOOGLE_CLOUD_LOCATION=us-east5
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/adc-or-service-account.json

# -----------------------------
# Optional debug toggles
# -----------------------------
# DAX_GEMINI_ALLOW_ADC_IMPORT=0
